# Required for KI-Beratung (api/ki-consulting.js) on Vercel
OPENROUTER_API_KEY=your_openrouter_api_key

# Required for Rechnungs-Upload (api/document-reader.js) on Vercel — exact name!
GEMINI_API_KEY=your_gemini_api_key

# Optional: output length (helps avoid truncated KI replies; continuation uses continuation max)
OPENROUTER_MAX_OUTPUT_TOKENS=2048
OPENROUTER_CONTINUATION_MAX_TOKENS=1536
# Required to read logs from /api/prompt-logs (Bearer token or ?token=...)
PROMPT_LOG_READ_TOKEN=replace_with_a_strong_random_token

# Optional logging behavior for /api/ki-consulting
# off | metadata | full
PROMPT_LOGGING=metadata
# console | kv | file | off
PROMPT_LOG_DEST=console
PROMPT_LOG_MAX_CHARS=800
PROMPT_LOG_SALT=replace_with_random_salt

# Optional KV namespace and retention tuning
PROMPT_LOG_KV_NAMESPACE=promptlog
PROMPT_LOG_TTL_SECONDS=2592000
PROMPT_LOG_MAX_EVENTS=5000

# Required only when PROMPT_LOG_DEST=kv or when using /api/prompt-logs with KV
KV_REST_API_URL=
KV_REST_API_TOKEN=
